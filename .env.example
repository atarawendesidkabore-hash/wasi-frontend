# WASI backend terminal API (optional; auto-detected by index.html)
# VITE_WASI_API_URL=http://localhost:8000

# Dedicated Banking API (prevents conflict with wasi-backend-api)
# VITE_WASI_BANKING_API_URL=http://localhost:8010

# Frontend feature flags
# VITE_FEATURE_FINANCE=true

# Banking API auth config (server-side)
# BANKING_JWT_SECRET=replace-with-a-long-random-secret
# BANKING_JWT_EXPIRES_IN=12h
# BANKING_PASSWORD_PEPPER=optional-extra-secret-for-password-hashing
# LEGACY_PASSWORD_SECRET=only-if-you-need-to-verify-legacy-sha256-passwords

# Auth hardening
# AUTH_RATE_LIMIT_WINDOW_MS=1800000
# AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Internal control thresholds
# BANKING_CLIENT_TRANSFER_MAX_CENTIMES=50000000
# BANKING_APPROVAL_THRESHOLD_CENTIMES=100000000

# Demo users are disabled by default and require explicit passwords
# WASI_ALLOW_DEMO_USERS=false
# WASI_DEMO_CLIENT_PASSWORD=change-me
# WASI_DEMO_TELLER_PASSWORD=change-me
# WASI_DEMO_MANAGER_PASSWORD=change-me

# Anthropic API (used by POST /api/chat)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# LLM provider routing for /api/chat: auto | anthropic | ollama | snapshot
# LLM_PROVIDER=auto

# Ollama local API (fallback or primary)
# OLLAMA_API_URL=http://127.0.0.1:11434/api/chat
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_TIMEOUT_MS=20000

# ── Security Alerts ────────────────────────────────────────
# ALERT_LARGE_TRANSFER_CENTIMES=10000000
# ALERT_FAILED_LOGIN_SPIKE=3

# ── Cloud deployment defaults ─────────────────────────────
# NODE_ENV=production
# PORT=8010
# VITE_WASI_BANKING_API_URL=https://your-wasi-web-api.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-wasi-web.onrender.com
